# Alapaap Dashboard - Development Environment
# Copy this file to .env and adjust values as needed.

# Server
ALAPAAP_PORT=3000
ALAPAAP_HOST=0.0.0.0

# Database
ALAPAAP_DB_PATH=./data/alapaap.db

# Authentication
ALAPAAP_JWT_EXPIRY=8h

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ClickHouse retention (storage cleanup APIs). Empty allowed DBs = all databases except deny list.
# ALAPAAP_CH_RETENTION_ALLOWED_DBS=analytics,logs
# ALAPAAP_CH_MAX_ALTER_DELETE_ROWS=50000000
# ALAPAAP_CH_MAX_DROP_PARTITIONS=500
# ALAPAAP_CH_MUTATION_TIMEOUT_MS=120000

# ClickHouse maintenance (automated housekeeping). Set to "0" to disable.
# ALAPAAP_CH_MAINTENANCE_ENABLED=1
# ALAPAAP_CH_MAINTENANCE_INTERVAL_MS=86400000
# ALAPAAP_CH_SYS_LOG_TTL_DAYS=7
# ALAPAAP_CH_MAX_INACTIVE_PARTS=500
# ALAPAAP_CH_MAX_PARTS_PER_TABLE=3000
# ALAPAAP_CH_STALE_MUTATION_MINS=120

# Docker
DOCKER_SOCKET=/var/run/docker.sock

# Network check module (TCP reachability + local listeners)
# When unset or not "1", probes only localhost, RFC1918, and typical private IPv6 (see network-check module).
# Link-local 169.254.0.0/16 is always blocked (metadata / cloud endpoints).
ALAPAAP_NETWORK_ALLOW_PUBLIC=
# Fixed in config/default.js unless extended: defaultTcpTimeoutMs 3000, maxTcpTimeoutMs 15000, maxBatchPorts 32

# Nanobot cron editor (nanobot-cron module)
# Explicit sources: JSON { key: absolutePath } for individually named cron files
ALAPAAP_NANOBOT_CRON_SOURCES={"nanobot":"/home/ubuntu/apps/nanobot/cron/jobs.json"}
# Auto-scan: comma-separated parent dirs; each child with cron/jobs.json becomes a source
ALAPAAP_NANOBOT_CRON_SCAN_DIRS=
# Optional: comma-separated base dirs; all source paths must lie under one of them (empty = no restriction)
ALAPAAP_NANOBOT_CRON_ALLOWED_BASES=/home/ubuntu/apps

# Nanobot workspace file manager (nanobot-workspace module)
# Explicit sources: JSON { key: absoluteWorkspacePath }
ALAPAAP_NANOBOT_WORKSPACE_SOURCES={"nanobot":"/home/ubuntu/.nanobot/workspace"}
# Auto-scan: comma-separated parent dirs; each child with AGENTS.md or .nanobot/ becomes a source
ALAPAAP_NANOBOT_WORKSPACE_SCAN_DIRS=
# Optional: comma-separated base dirs; all paths must lie under one (empty = no restriction)
ALAPAAP_NANOBOT_WORKSPACE_ALLOWED_BASES=/home/ubuntu
# Protected files that cannot be deleted (comma-separated, relative to workspace root)
# Default: AGENTS.md,HEARTBEAT.md,SOUL.md,TOOLS.md,USER.md,memory/MEMORY.md,memory/history.jsonl,cron/jobs.json,config.json
# ALAPAAP_NANOBOT_WORKSPACE_PROTECTED_FILES=
# Max file size for read/write (bytes, default 1MB)
# ALAPAAP_NANOBOT_WORKSPACE_MAX_FILE_SIZE=1048576

# Nanobot ClickHouse logs viewer (nanobot-clickhouse-logs module)
# Database and table containing OpenRouter traces. Defaults: default / OPENROUTER_TRACES
ALAPAAP_NANOBOT_CH_DB=default
ALAPAAP_NANOBOT_CH_TABLE=OPENROUTER_TRACES
# Optional: comma-separated column names to search (empty = auto-detect all String columns)
# ALAPAAP_NANOBOT_CH_SEARCH_COLS=model,error,trace_id
